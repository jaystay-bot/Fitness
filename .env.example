# Apex Protocol — environment variables.
# Engine and free experience run without any of these. The launch-readiness
# commercial layer (N=006) requires the following groups for production.

# --- App ---
NEXT_PUBLIC_APP_URL=https://apex-protocol.app

# --- Demo mode (portfolio) ---
# When "true", every visitor is granted Pro access so the full product
# (30-day timeline, lab parser, bottle scanner) is visible in a public demo
# without a subscription. Unset / "false" uses the real tier === "pro" check.
# Turn OFF for commercial launch.
NEXT_PUBLIC_DEMO_MODE=

# --- Clerk (auth, email-only sign-in) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Stripe (subscription) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# --- Supabase (subscriptions table only) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM="Apex Protocol <protocol@apex-protocol.app>"

# --- N=010: feedback widget admin ---
# Single password gate for /admin/feedback during the user-testing phase.
# A richer auth layer can ship later.
ADMIN_PASSWORD=

# --- Pro tier email allowlist ---
# Comma-separated. Any signed-in Clerk user whose primary email address
# matches an entry here is granted Pro tier by /api/subscription, regardless
# of Stripe subscription state. The hardcoded baseline lives in
# lib/proAccess.ts; this env var is purely additive (use it to grant Pro
# to a new tester without a code change).
PRO_EMAIL_ALLOWLIST=

# --- N=015: Amazon action plugin ---
# Amazon Associates affiliate tag, e.g. "apex-protocol-20". Configured
# in Vercel for both Production and Preview before launch. When unset,
# the Fulfill button still works and routes the user to Amazon — just
# without an affiliate attribution, so no revenue accrues until the tag
# is configured. Read at request time by /api/fulfillment/click.
AMAZON_ASSOCIATES_TAG=

# --- N=016: Telehealth deep-link plugin ---
# Base URL of the telehealth provider's landing page, e.g.
# "https://www.sesamecare.com/". Configured in Vercel for both
# Production and Preview before launch. When unset, the SpeakToDoctor
# button still works and routes the user to a generic fallback landing
# page; users are not directed to the intended provider until the
# variable is configured. Read at request time by /api/fulfillment/click.
TELEHEALTH_PROVIDER_URL=
