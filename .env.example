# Apex Protocol — environment variables.
# Engine and free experience run without any of these. The launch-readiness
# commercial layer (N=006) requires the following groups for production.

# --- App ---
NEXT_PUBLIC_APP_URL=https://apex-protocol.app

# --- Clerk (auth, email-only sign-in) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Stripe (subscription) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# --- Supabase (subscriptions table only) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM="Apex Protocol <protocol@apex-protocol.app>"
